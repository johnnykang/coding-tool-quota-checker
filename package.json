{
  "name": "coding-tool-quota-checker",
  "version": "1.0.1",
  "description": "Stream Deck Plugin to check Copilot interactions quota",
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w",
    "validate": "streamdeck validate au.jkang.codingtoolquotachecker.sdPlugin",
    "pack": "streamdeck pack au.jkang.codingtoolquotachecker.sdPlugin"
  },
  "dependencies": {
    "@elgato/streamdeck": "^2.1.0"
  },
  "devDependencies": {
    "@elgato/cli": "^1.7.3",
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/node": "^20.11.16",
    "rollup": "^4.9.6",
    "tslib": "^2.8.1",
    "typescript": "^5.3.3"
  }
}
