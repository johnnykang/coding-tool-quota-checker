{
    "$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
    "UUID": "au.jkang.codingtoolquotachecker",
    "Name": "AI Quota",
    "Version": "1.0.0.0",
    "Author": "Johnny Kang",
    "Description": "Checks GitHub Copilot remaining premium requests and Claude Code usage.",
    "Icon": "imgs/plugin-icon",
    "Category": "AI Quota",
    "CategoryIcon": "imgs/category-icon",
    "Actions": [
        {
            "Name": "Copilot Quota",
            "UUID": "au.jkang.codingtoolquotachecker.action",
            "Icon": "imgs/copilot-action",
            "Tooltip": "Displays remaining Copilot premium quota",
            "PropertyInspectorPath": "pi.html",
            "States": [
                {
                    "Image": "imgs/copilot-provider",
                    "TitleAlignment": "middle"
                }
            ],
            "Controllers": [
                "Keypad"
            ]
        },
        {
            "Name": "Claude Code Usage",
            "UUID": "au.jkang.codingtoolquotachecker.claude",
            "Icon": "imgs/claude-action",
            "Tooltip": "Displays Claude Code usage percentage for the selected window",
            "PropertyInspectorPath": "pi-claude.html",
            "States": [
                {
                    "Image": "imgs/claude-provider",
                    "TitleAlignment": "middle"
                }
            ],
            "Controllers": [
                "Keypad"
            ]
        },
        {
            "Name": "Claude Code Credits",
            "UUID": "au.jkang.codingtoolquotachecker.claudecredits",
            "Icon": "imgs/claude-action",
            "Tooltip": "Displays remaining Claude Code prepaid credits",
            "PropertyInspectorPath": "pi-claude-credits.html",
            "States": [
                {
                    "Image": "imgs/claude-provider",
                    "TitleAlignment": "middle"
                }
            ],
            "Controllers": [
                "Keypad"
            ]
        },
        {
            "Name": "Antigravity Quota",
            "UUID": "au.jkang.codingtoolquotachecker.antigravity",
            "Icon": "imgs/antigravity-action",
            "Tooltip": "Displays remaining Antigravity model quota",
            "PropertyInspectorPath": "pi-antigravity.html",
            "States": [
                {
                    "Image": "imgs/antigravity-provider",
                    "TitleAlignment": "middle"
                }
            ],
            "Controllers": [
                "Keypad"
            ]
        },
        {
            "Name": "OpenAI Credits",
            "UUID": "au.jkang.codingtoolquotachecker.openaicredits",
            "Icon": "imgs/openai-action",
            "Tooltip": "Displays remaining OpenAI credit balance",
            "PropertyInspectorPath": "pi-openai-credits.html",
            "States": [
                {
                    "Image": "imgs/openai-provider",
                    "TitleAlignment": "middle"
                }
            ],
            "Controllers": [
                "Keypad"
            ]
        },
        {
            "Name": "DeepSeek Balance",
            "UUID": "au.jkang.codingtoolquotachecker.deepseek",
            "Icon": "imgs/deepseek-action",
            "Tooltip": "Displays remaining DeepSeek API balance",
            "PropertyInspectorPath": "pi-deepseek.html",
            "States": [
                {
                    "Image": "imgs/deepseek-provider",
                    "TitleAlignment": "middle"
                }
            ],
            "Controllers": [
                "Keypad"
            ]
        },
        {
            "Name": "FAL.AI Balance",
            "UUID": "au.jkang.codingtoolquotachecker.fal",
            "Icon": "imgs/fal-action",
            "Tooltip": "Displays remaining FAL.AI credit balance",
            "PropertyInspectorPath": "pi-fal-credits.html",
            "States": [
                {
                    "Image": "imgs/fal-provider",
                    "TitleAlignment": "middle"
                }
            ],
            "Controllers": [
                "Keypad"
            ]
        },
        {
            "Name": "Refresh Timer",
            "UUID": "au.jkang.codingtoolquotachecker.countdown",
            "Icon": "imgs/refresh-action",
            "Tooltip": "Countdown to next refresh. Press to refresh all buttons.",
            "PropertyInspectorPath": "pi-countdown.html",
            "States": [
                {
                    "Image": "imgs/refresh-provider",
                    "TitleAlignment": "middle"
                }
            ],
            "Controllers": [
                "Keypad"
            ]
        }
    ],
    "CodePath": "bin/plugin.js",
    "SDKVersion": 2,
    "Software": {
        "MinimumVersion": "6.6"
    },
    "OS": [
        {
            "Platform": "windows",
            "MinimumVersion": "10"
        },
        {
            "Platform": "mac",
            "MinimumVersion": "10.15"
        }
    ],
    "Nodejs": {
        "Version": "20"
    }
}
